{
  "_comment": "OpenCode v1.17.x",
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "anthropic/claude-opus-4-7",
      "ultrawork": { "model": "anthropic/claude-opus-4-7", "variant": "max" }
    },
    "librarian": { "model": "google/gemini-3.5-flash" },
    "explore": { "model": "xai/grok-4.3" },
    "oracle": { "model": "openai/gpt-5.5", "variant": "high" }
  },
  "categories": {
    "quick": { "model": "openai/gpt-4o-mini" },
    "unspecified-low": { "model": "anthropic/claude-sonnet-4-6" },
    "unspecified-high": { "model": "anthropic/claude-opus-4-7", "variant": "max" },
    "writing": { "model": "moonshot/kimi-k2.6" },
    "visual-engineering": { "model": "google/gemini-3.1-pro", "variant": "high" }
  },
  "experimental": { "aggressive_truncation": true, "task_system": true },
  "tmux": { "enabled": false }
}
