# ====================================================================
# ATT&CK RAG — .gitignore
# ====================================================================

# ---- Build artifacts ----
attck_vec.db
*.db
java/target/
python/models/

# ---- Python ----
__pycache__/
*.pyc
.venv/

# ---- Config: exclude generated JSON but keep reference files ----
# Generated by index_builder.py / setup.py (data dumps)
config/*.json
# But keep the reference config files in config/
!config/mdbook-parser.json
!config/progressive-disclosure.json

# ---- IDE / Editor ----
.idea/
*.iml
.vscode/
.project
.classpath
.settings/

# ---- OS ----
Thumbs.db
.DS_Store
